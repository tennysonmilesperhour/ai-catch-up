# Stripe payment link (create manually in Stripe dashboard, paste URL here)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/xxxxx

# The email that unlocks admin access (yours)
ADMIN_EMAIL=you@example.com

# Optional paid-email allowlist. When set, only listed addresses (plus the
# admin) can reach buyer surfaces under /admin. Unset = preview mode (any
# authed email gets in), which matches the v1.x landing copy. Comma- or
# whitespace-separated, case-insensitive. Example:
#   PAID_EMAILS=alice@example.com,bob@example.com
PAID_EMAILS=

# 32+ random characters used to sign session cookies. Change it to invalidate all sessions.
SESSION_SECRET=generate-a-long-random-string-and-paste-it-here

# Public-facing site URL (used in metadata, canonical URLs, etc.)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# GitHub handle for the Nexus auto-sync (public repos). Required for sync.
GITHUB_USERNAME=yourhandle

# Optional: GitHub personal access token (readonly). Only needed to raise
# the unauthenticated rate limit or to include private repos. Create at
# https://github.com/settings/tokens with the 'public_repo' scope.
GITHUB_TOKEN=

# ---------------------------------------------------------------
# Blog publish endpoint (POST /api/blog/publish)
# ---------------------------------------------------------------
# Shared secret the newsletter bot includes as `Authorization: Bearer <secret>`.
# Generate with: openssl rand -hex 32
BLOG_PUBLISH_SECRET=

# GitHub fine-grained PAT with Contents: Read and Write scope on this repo.
# Used by the publish endpoint to commit new posts to /content/blog/.
# Create at https://github.com/settings/personal-access-tokens/new and
# limit it to the ai-catch-up repo. Keep separate from GITHUB_TOKEN.
GITHUB_BLOG_TOKEN=

# Optional overrides for the publish target. Defaults match the live repo.
GITHUB_BLOG_REPO_OWNER=tennysonmilesperhour
GITHUB_BLOG_REPO=ai-catch-up
GITHUB_BLOG_BRANCH=main

# ---------------------------------------------------------------
# Subscribe endpoint (POST /api/subscribe)
# ---------------------------------------------------------------
# Vercel's serverless filesystem is read-only at runtime, so the file-based
# subscribers.json fallback in /api/subscribe only works in local dev. In
# production every subscription is logged to stdout (visible in Vercel
# Functions logs) AND, if SUBSCRIBE_WEBHOOK_URL is set, POSTed to that URL
# as `{ "email": "...", "createdAt": "..." }`. Wire this up to whatever
# you actually use (Resend audience, ConvertKit, Zapier, Make, Google
# Apps Script, etc.) so emails land somewhere queryable.
SUBSCRIBE_WEBHOOK_URL=
# Optional bearer token, sent as `Authorization: Bearer <token>` if set.
SUBSCRIBE_WEBHOOK_TOKEN=

# ---------------------------------------------------------------
# GitHub OAuth (sign in with GitHub on /login)
# ---------------------------------------------------------------
# Create an OAuth app at https://github.com/settings/developers and set the
# Authorization callback URL to: <NEXT_PUBLIC_SITE_URL>/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
